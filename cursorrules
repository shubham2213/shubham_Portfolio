## 🌐 API & DATA RULES

### Frontend API Calls
```typescript
// ✅ CORRECT — always use the Axios instance from lib
import api from '@/lib/axios'

const { data } = await api.get<ApiResponse<ProjectDTO[]>>('/projects')

// ❌ WRONG — never use raw fetch or import axios directly
import axios from 'axios'
const res = await fetch('/api/projects')
```

### Always Handle All States
```typescript
// ✅ CORRECT — loading + error + success always handled
const [projects, setProjects] = useState<ProjectDTO[]>([])
const [loading, setLoading]   = useState(true)
const [error, setError]       = useState<string | null>(null)

useEffect(() => {
  api.get('/projects')
    .then(res => setProjects(res.data.data))
    .catch(() => setError('Failed to load projects'))
    .finally(() => setLoading(false))
}, [])
```

### Backend Validation
```typescript
// ✅ CORRECT — always validate with Zod before touching DB
import { z } from 'zod'

const contactSchema = z.object({
  name:    z.string().min(2).max(100),
  email:   z.string().email(),
  message: z.string().min(10).max(2000),
})

// Apply validate middleware on the route, not in the controller
router.post('/', contactLimiter, validate(contactSchema), createMessage)
```

### Backend Responses — Always Use This Shape
```typescript
// ✅ CORRECT — consistent ApiResponse shape always
res.status(200).json({ success: true, data: projects })
res.status(201).json({ success: true, message: 'Message received.' })
res.status(400).json({ success: false, error: 'Validation failed', details: [...] })
res.status(404).json({ success: false, error: 'Project not found' })
res.status(500).json({ success: false, error: 'Internal server error' })

// ❌ WRONG — never send inconsistent shapes or raw errors
res.send(projects)
res.json({ message: 'ok' })
res.status(500).json({ error: err.stack }) // never expose stack traces
```

### Prisma Usage
```typescript
// ✅ CORRECT — always use the singleton
import { prisma } from '@/lib/prisma'

// ❌ WRONG — never import PrismaClient directly in controllers
import { PrismaClient } from '@prisma/client'
const prisma = new PrismaClient()
```

