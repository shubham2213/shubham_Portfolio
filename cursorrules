## 🎬 ANIMATION RULES

### GSAP
```typescript
// ✅ CORRECT — always use the lib instance, not direct gsap import
import { gsap, ScrollTrigger } from '@/lib/gsap'

// ✅ CORRECT — always kill ScrollTrigger in cleanup
useEffect(() => {
  const ctx = gsap.context(() => {
    gsap.from(ref.current, {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: ref.current,
        start: 'top 85%',
        toggleActions: 'play none none none',
      }
    })
  }, ref)

  return () => ctx.revert() // ← ALWAYS clean up
}, [])

// ✅ CORRECT — check reduced motion before ALL GSAP animations
const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
if (!prefersReduced) {
  // GSAP animation here
}

// ❌ WRONG — never use setTimeout for animation sequencing
setTimeout(() => gsap.to(...), 500)

// ✅ CORRECT — use GSAP timeline delays instead
const tl = gsap.timeline()
tl.from(el1, { ... })
  .from(el2, { ... }, '+=0.2')
```

### Framer Motion
```typescript
// ✅ CORRECT — define variants outside the component
const cardVariants = {
  hidden:  { opacity: 0, y: 40 },
  visible: { opacity: 1, y: 0, transition: { duration: 0.6, ease: [0.16, 1, 0.3, 1] } }
}

// ✅ CORRECT — use AnimatePresence for mount/unmount
<AnimatePresence>
  {isOpen && <TerminalEasterEgg />}
</AnimatePresence>
```

### Three.js (React Three Fiber)
```typescript
// ✅ CORRECT — always use useFrame, never setInterval
useFrame((state, delta) => {
  meshRef.current.rotation.y += delta * 0.5
})

// ✅ CORRECT — dispose geometry and material on unmount
useEffect(() => {
  return () => {
    geometry.dispose()
    material.dispose()
  }
}, [])
```

### CSS Animations
```css
/* ✅ CORRECT — only animate these properties (no layout thrashing) */
transform, opacity, filter, box-shadow, color, border-color

/* ❌ WRONG — never animate these (causes reflow) */
width, height, margin, padding, top, left
```

### Cursor / Mouse Position Updates
```typescript
// ✅ CORRECT — use ref.style directly, never React state for cursor/mouse
const spotlightRef = useRef<HTMLDivElement>(null)

document.addEventListener('mousemove', (e) => {
  spotlightRef.current?.style.setProperty('--cursor-x', `${e.clientX}px`)
  spotlightRef.current?.style.setProperty('--cursor-y', `${e.clientY}px`)
})

// ❌ WRONG — never use useState for mouse position (causes constant re-renders)
const [mouseX, setMouseX] = useState(0)
```

