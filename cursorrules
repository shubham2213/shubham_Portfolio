## 💻 TYPESCRIPT RULES

```typescript
// ✅ CORRECT
const data: unknown = response.data
if (typeof data === 'string') { /* use data */ }

// ❌ WRONG — never use any
const data: any = response.data

// ✅ CORRECT — always type component props
interface GlitchTextProps {
  text: string
  intensity: 'low' | 'medium' | 'high'
  interval?: number
  className?: string
}

// ✅ CORRECT — interfaces for all data shapes
interface Project {
  id: string
  slug: string
  title: string
  // ...
}

// ✅ CORRECT — named exports everywhere (except page-level)
export const GlitchText = ({ text, intensity }: GlitchTextProps) => { ... }

// ❌ WRONG — no default export on reusable components
export default GlitchText
```

- strict mode is ON — never disable it
- noImplicitAny is ON — every variable must be typed
- All interfaces live in `src/types/index.ts` or `shared/types.ts`
- Use `unknown` + type narrowing instead of `any` always

